async function llamadoAlPost(datos) {
    try {
      const response = await fetch('http://localhost:4000/Videojuegos',{
          method:"POST", //GET, POST, PUT o DELETE
          headers: { //Esto va siempre, solo aclaro que va en tipo JSON
              "Content-Type": "application/json",
            },
          body: JSON.stringify(datos) //JSON.stringify convierte de objeto a JSON
      })
  
      console.log(response) //Imprimo la respuesta en formato JSON
      
      let result = await response.json()//Desarma el json y lo arma como un objeto
      console.log(result)
      document.getElementById("mensajeput").innerHTML = result.message

    } catch (error) {
      console.log('Error:', error.message)
      document.getElementById("mensajeput").innerHTML = "Error al agregar el videojuego"
    }
}